[Unit]
Description=Dush.kz publish storefront
After=network.target postgresql.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/var/www/dush.kz/shared/builder
# Сборка на слабом сервере: не мешаем сайту отвечать.
Nice=10
IOSchedulingClass=idle
TimeoutStartSec=1800
ExecStart=/var/www/dush.kz/shared/publish.sh
